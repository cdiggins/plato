<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Plato conformance suite, V2 emitter edition (docs/plato-roadmap.md Phase 2.4).

    Identical to Ara3D.SDK.ConformanceTests except that Generated\ is produced with the
    extension-style C# emitter (Plato.CLI "csharp-style=extensions" flag): classic extension
    methods, one static class per Plato library. Compiles with the DEFAULT LangVersion on
    net8.0 (the C# 14 extension-block dependency was dropped in the Phase 2 revision).

    The test sources and KnownFailures.json are LINKED from the V1 project (never copied):
    the two suites must stay literally the same code so any result difference is
    attributable to the emitter alone. Expected result: identical to V1
    (178 tests: 142 pass / 36 ignored-known / 0 fail).

    Run tools\regen-conformance-v2.ps1 (studio repo) before building: Generated\ is
    not committed. Lives in the Plato repo under conformance\ since the Phase 2
    revision repo restructuring; package versions pinned, SDK project references
    reach into ara3d-sdk via the studio monorepo layout.

    Deliberately not added to any .sln (wire into CI explicitly).
  -->

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>disable</Nullable>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <PlatformTarget>x64</PlatformTarget>
    <Platforms>AnyCPU;x64</Platforms>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <!-- Generated code produces a large number of benign warnings; keep test output readable. -->
    <NoWarn>$(NoWarn);CS0108;CS0114;CS0660;CS0661;CS1591</NoWarn>
  </PropertyGroup>

  <Import Project="..\..\Plato.Intrinsics\Plato.Intrinsics.projitems" Label="Shared" />

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.8.0" />
    <PackageReference Include="NUnit" Version="3.14.0" />
    <PackageReference Include="NUnit3TestAdapter" Version="4.5.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\..\ara3d-sdk\src\Ara3D.Collections\Ara3D.Collections.csproj" />
    <ProjectReference Include="..\..\..\..\ara3d-sdk\src\Ara3D.Memory\Ara3D.Memory.csproj" />
    <ProjectReference Include="..\..\..\..\ara3d-sdk\src\Ara3D.Utils\Ara3D.Utils.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- The SAME test sources as the V1 suite, linked (do not copy, do not fork). -->
    <Compile Include="..\Ara3D.SDK.ConformanceTests\ConformanceSupport.cs" Link="ConformanceSupport.cs" />
    <Compile Include="..\Ara3D.SDK.ConformanceTests\LawTests.cs" Link="LawTests.cs" />
    <Compile Include="..\Ara3D.SDK.ConformanceTests\WitnessRunnerTests.cs" Link="WitnessRunnerTests.cs" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="NUnit.Framework" />
    <None Include="..\Ara3D.SDK.ConformanceTests\KnownFailures.json" Link="KnownFailures.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
