<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Plato conformance suite, V2-RUNTIME edition.

    Semantic coverage for the all-extension-methods runtime (Plato.Intrinsics.V2). Identical
    to Ara3D.SDK.ConformanceTests.Scalar except it imports Plato.Intrinsics.V2 (not V1) and
    Generated\ is produced with the full V2 adoption recipe, the no-properties recipe that
    Plato.Generated.Optimized uses: the wrapper structs expose no properties, and V2's
    handwritten intrinsics live in the per-type "Intrinsics" extension classes.

    Consolidation plan C2 (2026-07-12): this is now THE Plato conformance suite. The four legacy
    recipe suites (V1 / V2 / Opt / Scalar) were retired and their shared test sources
    (ConformanceSupport.cs, LawTests.cs, WitnessRunnerTests.cs, KnownFailures.json) MOVED here, so
    this project is self-contained. (Rename to Ara3D.SDK.ConformanceTests deferred to C5.)

    Run tools\regen-conformance-v2runtime.ps1 (studio repo) before building: Generated\ is not
    committed. Deliberately not added to any .sln (wire into CI explicitly).
  -->

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>disable</Nullable>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <PlatformTarget>x64</PlatformTarget>
    <Platforms>AnyCPU;x64</Platforms>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <!-- Generated code produces a large number of benign warnings; keep test output readable. -->
    <NoWarn>$(NoWarn);CS0108;CS0114;CS0660;CS0661;CS1591</NoWarn>
  </PropertyGroup>

  <Import Project="..\..\Plato.Intrinsics.V2\Plato.Intrinsics.V2.projitems" Label="Shared" />

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.8.0" />
    <PackageReference Include="NUnit" Version="3.14.0" />
    <PackageReference Include="NUnit3TestAdapter" Version="4.5.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\..\ara3d-sdk\src\Ara3D.Collections\Ara3D.Collections.csproj" />
    <ProjectReference Include="..\..\..\..\ara3d-sdk\src\Ara3D.Memory\Ara3D.Memory.csproj" />
    <ProjectReference Include="..\..\..\..\ara3d-sdk\src\Ara3D.Utils\Ara3D.Utils.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Test sources are LOCAL to this project (SDK-style glob auto-includes the .cs files). -->
    <Using Include="NUnit.Framework" />
    <None Update="KnownFailures.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
