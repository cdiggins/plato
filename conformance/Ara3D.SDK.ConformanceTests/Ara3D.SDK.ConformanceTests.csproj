<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Plato conformance test suite (studio docs/plato-roadmap.md Phase 1; lives in the
    Plato repo under conformance\ since the Phase 2 revision repo restructuring).

    This project does NOT reference Ara3D.Geometry. Instead it compiles its own
    Generated\ folder, produced by the studio repo's tools\regen-conformance.ps1
    from the merge of plato-src (production, frozen) and plato-test-src
    (laws.plato + witness.plato).
    That keeps the Law_/Witness_ functions out of the production API and avoids
    duplicate-type collisions with the shipped Plato.Generated output.

    Run tools\regen-conformance.ps1 (studio repo) before building: Generated\ is
    not committed. Package versions are pinned here (this project is outside the
    ara3d-sdk Directory.Build.props scope); the Ara3D.Collections/Memory/Utils
    project references reach into ara3d-sdk via the studio monorepo layout.

    Deliberately not added to any .sln (Phase 1 harness; wire into CI explicitly).
  -->

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>disable</Nullable>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <PlatformTarget>x64</PlatformTarget>
    <Platforms>AnyCPU;x64</Platforms>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <!-- Generated code produces a large number of benign warnings; keep test output readable. -->
    <NoWarn>$(NoWarn);CS0108;CS0114;CS0660;CS0661;CS1591</NoWarn>
  </PropertyGroup>

  <Import Project="..\..\Plato.Intrinsics\Plato.Intrinsics.projitems" Label="Shared" />

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.8.0" />
    <PackageReference Include="NUnit" Version="3.14.0" />
    <PackageReference Include="NUnit3TestAdapter" Version="4.5.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\..\ara3d-sdk\src\Ara3D.Collections\Ara3D.Collections.csproj" />
    <ProjectReference Include="..\..\..\..\ara3d-sdk\src\Ara3D.Memory\Ara3D.Memory.csproj" />
    <ProjectReference Include="..\..\..\..\ara3d-sdk\src\Ara3D.Utils\Ara3D.Utils.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="NUnit.Framework" />
    <None Update="KnownFailures.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
