<Project Sdk="Microsoft.NET.Sdk">

  <!--
    THE Plato conformance suite.

    Semantic coverage for the live library: the all-extension-methods runtime (Plato.Intrinsics.V2)
    with Generated\ produced by the full V2 adoption recipe (extensions, scalar-erased,
    no-properties) that Plato.Generated.Optimized uses. Self-contained (the shared Law/Witness test
    sources live here). Consolidation plan C2 retired the four legacy recipe suites; C5 renamed this
    one from Ara3D.SDK.ConformanceTests.V2Runtime.

    Run tools\regen-conformance.ps1 (studio repo) before building: Generated\ is not committed.
    Deliberately not added to any .sln (wire into CI explicitly).
  -->

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>disable</Nullable>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <PlatformTarget>x64</PlatformTarget>
    <Platforms>AnyCPU;x64</Platforms>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <!-- Generated code produces a large number of benign warnings; keep test output readable. -->
    <NoWarn>$(NoWarn);CS0108;CS0114;CS0660;CS0661;CS1591</NoWarn>
  </PropertyGroup>

  <Import Project="..\..\Plato.Intrinsics.V2\Plato.Intrinsics.V2.projitems" Label="Shared" />

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.8.0" />
    <PackageReference Include="NUnit" Version="3.14.0" />
    <PackageReference Include="NUnit3TestAdapter" Version="4.5.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\..\ara3d-sdk\src\Ara3D.Collections\Ara3D.Collections.csproj" />
    <ProjectReference Include="..\..\..\..\ara3d-sdk\src\Ara3D.Memory\Ara3D.Memory.csproj" />
    <ProjectReference Include="..\..\..\..\ara3d-sdk\src\Ara3D.Utils\Ara3D.Utils.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Test sources are LOCAL to this project (SDK-style glob auto-includes the .cs files). -->
    <Using Include="NUnit.Framework" />
    <None Update="KnownFailures.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
