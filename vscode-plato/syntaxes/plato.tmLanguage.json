{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Plato",
  "scopeName": "source.plato",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#type-annotation" },
    { "include": "#function-declaration" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.plato",
          "begin": "/\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.line.double-slash.plato",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.interpolated.plato",
          "begin": "\\$\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.plato",
              "match": "\\\\."
            },
            {
              "name": "meta.interpolation.plato",
              "begin": "\\{",
              "end": "\\}",
              "patterns": [
                { "include": "$self" }
              ]
            }
          ]
        },
        {
          "name": "string.quoted.double.plato",
          "begin": "@?\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.plato",
              "match": "\\\\.|\"\""
            }
          ]
        },
        {
          "name": "string.quoted.single.plato",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.plato",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.plato",
          "match": "\\b0[xX][0-9a-fA-F]+[uUlL]*\\b"
        },
        {
          "name": "constant.numeric.binary.plato",
          "match": "\\b0[bB][01]+[uUlL]*\\b"
        },
        {
          "name": "constant.numeric.float.plato",
          "match": "\\b\\d+\\.\\d+([eE][+-]?\\d+)?[fFdDmM]?\\b"
        },
        {
          "name": "constant.numeric.integer.plato",
          "match": "\\b\\d+[uUlLfFdDmM]*\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.declaration.plato",
          "match": "\\b(unique|type|interface|concept|library)\\b"
        },
        {
          "name": "keyword.other.clause.plato",
          "match": "\\b(implements|inherits|where)\\b"
        },
        {
          "name": "keyword.control.plato",
          "match": "\\b(if|else|for|foreach|while|do|switch|case|default|break|continue|return|throw|try|catch|finally|yield|using)\\b"
        },
        {
          "name": "keyword.operator.expression.plato",
          "match": "\\b(and|or|is|as|in|typeof|nameof|new)\\b"
        },
        {
          "name": "storage.modifier.plato",
          "match": "\\b(ref|out|params)\\b"
        },
        {
          "name": "constant.language.boolean.plato",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.plato",
          "match": "\\bnull\\b"
        },
        {
          "name": "support.type.self.plato",
          "match": "\\bSelf\\b"
        },
        {
          "name": "keyword.other.default.plato",
          "match": "\\bdefault\\b"
        }
      ]
    },
    "type-annotation": {
      "patterns": [
        {
          "match": "(:)(\\s*)(\\$?[A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "punctuation.separator.colon.plato" },
            "3": { "name": "entity.name.type.plato" }
          }
        },
        {
          "match": "\\b(?:(unique)\\s+)?(type|interface|concept|library)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.plato" },
            "2": { "name": "keyword.declaration.plato" },
            "3": { "name": "entity.name.type.plato" }
          }
        }
      ]
    },
    "function-declaration": {
      "patterns": [
        {
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.plato" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.plato",
          "match": "=>"
        },
        {
          "name": "keyword.operator.comparison.plato",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.assignment.plato",
          "match": "\\+=|-=|\\*=|/=|%=|>>>=|>>=|<<=|&&=|\\|\\|=|&=|\\|=|\\^=|="
        },
        {
          "name": "keyword.operator.logical.plato",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.bitwise.plato",
          "match": "<<|>>|>>>|&|\\||\\^|~"
        },
        {
          "name": "keyword.operator.arithmetic.plato",
          "match": "\\+\\+|--|\\+|\\-|\\*|/|%"
        },
        {
          "name": "keyword.operator.ternary.plato",
          "match": "\\?|:"
        },
        {
          "name": "punctuation.accessor.plato",
          "match": "\\?\\.|\\."
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.terminator.statement.plato",
          "match": ";"
        },
        {
          "name": "punctuation.separator.comma.plato",
          "match": ","
        },
        {
          "name": "meta.brace.curly.plato",
          "match": "[{}]"
        },
        {
          "name": "meta.brace.round.plato",
          "match": "[()]"
        },
        {
          "name": "meta.brace.square.plato",
          "match": "[\\[\\]]"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.plato",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        },
        {
          "name": "variable.other.typevar.plato",
          "match": "\\$[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    }
  }
}
