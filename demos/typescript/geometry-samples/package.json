{
  "name": "geometry-samples",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Browser for geometry algorithms and data structures, rendered with Three.js. Samples are pure TypeScript modules, testable from Node.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:node": "tsc -p tsconfig.node.json",
    "gen:plato": "dotnet run --project ../../../Plato.CLI -- ../../plato-src ./src/plato --typescript",
    "test": "npm run build:node && node --test \"dist-node/tests/*.test.js\"",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "highlight.js": "^11.9.0",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/three": "^0.170.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
