<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Plato.Generated.Optimized - buildable golden of the extension-style, scalar-erased
    Plato standard library with the FULL OPTIMIZER PIPELINE ON. This is the intended
    adoption/shipping shape.

    Recipe (see Generated\README.md) - flags shown without the leading dashes:
        Plato.CLI plato-src Generated\Plato.Generated.Optimized
            csharp-style=extensions scalar=float
            optimize optimize-arrays inline methods loops

    Same recipe the Scalar conformance suite semantically gates. Diff against
    Plato.Generated.Unoptimized to see what the optimizer passes change.

    Regenerate with tools\regen-generated.ps1 (studio repo). The .g.cs files ARE committed
    (this is a golden); docs.html / interfaces.txt generator side-products are gitignored.
  -->

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>disable</Nullable>
    <IsPackable>false</IsPackable>
    <PlatformTarget>x64</PlatformTarget>
    <Platforms>AnyCPU;x64</Platforms>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <RootNamespace>Ara3D.Geometry</RootNamespace>
    <!-- Generated code produces a large number of benign warnings. -->
    <NoWarn>$(NoWarn);CS0108;CS0114;CS0660;CS0661;CS1591</NoWarn>
  </PropertyGroup>

  <!-- Link the handwritten intrinsics runtime (shared project). -->
  <Import Project="..\..\Plato.Intrinsics\Plato.Intrinsics.projitems" Label="Shared" />

  <ItemGroup>
    <ProjectReference Include="..\..\..\..\ara3d-sdk\src\Ara3D.Collections\Ara3D.Collections.csproj" />
    <ProjectReference Include="..\..\..\..\ara3d-sdk\src\Ara3D.Memory\Ara3D.Memory.csproj" />
    <ProjectReference Include="..\..\..\..\ara3d-sdk\src\Ara3D.Utils\Ara3D.Utils.csproj" />
  </ItemGroup>

</Project>
