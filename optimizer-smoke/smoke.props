<!--
  Shared build settings for the optimizer smoke-test projects.

  These are REAL csproj-backed libraries (not the shproj the golden ships as), so
  `dotnet build` actually compiles the generated C# — a compilation smoke test for
  each emitter recipe. Referenced by every Smoke.*/*.csproj via <Import>.

  Paths use $(MSBuildThisFileDirectory) so they resolve relative to THIS file,
  not the importing project (MSBuild resolves bare relative paths in an imported
  props against the importing project otherwise).
-->
<Project>

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>disable</Nullable>
    <IsPackable>false</IsPackable>
    <PlatformTarget>x64</PlatformTarget>
    <Platforms>AnyCPU;x64</Platforms>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <!-- Smoke test only cares that the generated code COMPILES. Silence the benign
         generated-code warnings (hiding, unreachable, unused locals from unrolling). -->
    <NoWarn>$(NoWarn);CS0108;CS0114;CS0660;CS0661;CS1591;CS0162;CS0219;CS0169</NoWarn>
    <!-- Generated/ is regenerated by regen-smoke.ps1 and is not committed. -->
    <EnableDefaultCompileItems>true</EnableDefaultCompileItems>
  </PropertyGroup>

  <!-- The handwritten Plato runtime (Number/Vector/Matrix wrappers, MakeArray, ...). -->
  <Import Project="$(MSBuildThisFileDirectory)..\Plato.Intrinsics\Plato.Intrinsics.projitems" Label="Shared" />

  <!-- Collection adapters (ReadOnlyList / IReadOnlyList2D / ...) the generated code targets. -->
  <ItemGroup>
    <ProjectReference Include="$(MSBuildThisFileDirectory)..\..\..\ara3d-sdk\src\Ara3D.Collections\Ara3D.Collections.csproj" />
    <ProjectReference Include="$(MSBuildThisFileDirectory)..\..\..\ara3d-sdk\src\Ara3D.Memory\Ara3D.Memory.csproj" />
    <ProjectReference Include="$(MSBuildThisFileDirectory)..\..\..\ara3d-sdk\src\Ara3D.Utils\Ara3D.Utils.csproj" />
  </ItemGroup>

</Project>
